# Copy this file to `.env` and fill in your keys. NEVER commit the real .env.

# ============ LLM provider(s) ============
# Primary provider + an optional comma-separated FALLBACK chain, tried in order
# when the primary errors or rate-limits. Providers: cerebras | mistral | groq |
# google | ollama | anthropic.
CITEWISE_PROVIDER=cerebras
CITEWISE_FALLBACK_PROVIDERS=mistral

# Each provider has a sensible default model. Leave CITEWISE_MODEL unset when using
# a chain (it only sets the primary); override one provider with CITEWISE_<PROVIDER>_MODEL.
# CITEWISE_MISTRAL_MODEL=mistral-large-latest

# --- Cerebras (FREE ~1M tokens/day, NO card; gpt-oss-120b with tool calling). https://cloud.cerebras.ai ---
CEREBRAS_API_KEY=your-cerebras-api-key-here
# --- Mistral (free tier ~1B tokens/month, tool calling; needs phone verify). https://console.mistral.ai ---
MISTRAL_API_KEY=your-mistral-api-key-here

# --- Groq (free; 70B = 12k tok/min + 100k/day, llama-3.1-8b-instant = bigger daily quota). https://console.groq.com/keys ---
GROQ_API_KEY=your-groq-api-key-here
# CITEWISE_GROQ_MODEL=llama-3.3-70b-versatile

# --- Ollama (fully local, UNLIMITED, free; use a tool-capable model). https://ollama.com ---
# CITEWISE_PROVIDER=ollama
# CITEWISE_OLLAMA_MODEL=qwen2.5:14b

# --- Google Gemini (NOTE: free tier is region/account-restricted). ---
# GOOGLE_API_KEY=your-google-api-key-here

# --- Anthropic Claude (needs credits). https://console.anthropic.com ---
# ANTHROPIC_API_KEY=your-anthropic-api-key-here

# ============ Web search tool (Tavily) ============
# Free key: https://app.tavily.com
TAVILY_API_KEY=your-tavily-api-key-here

# ============ Web app: accounts & history ============
# Login is email + password; on success the server stores a signed JWT in an
# httponly cookie. Set a long random secret in production (anyone who knows it
# can forge a login). Generate one with:
#   python -c "import secrets; print(secrets.token_urlsafe(48))"
# CITEWISE_JWT_SECRET=replace-with-a-long-random-string

# Guest login (type a name, no password). Kept on so the app always works during
# a live demo. Set to false to require an email account.
# CITEWISE_ALLOW_GUEST=true
# Where local accounts + history are stored, and how long a login lasts (days).
# CITEWISE_DB=citewise.db
# CITEWISE_SESSION_DAYS=30

# ============ Observability (LangSmith) — optional ============
LANGSMITH_TRACING=false
LANGSMITH_API_KEY=your-langsmith-api-key-here
LANGSMITH_PROJECT=citewise

# ============ Behaviour (optional tuning) ============
# Max times the Fact-Checker may loop back to the Researcher for more evidence.
MAX_RESEARCH_RETRIES=2
# Claim budget — higher = more complete reports, but more fact-checking work.
# CITEWISE_MAX_CLAIMS=24
# CITEWISE_MAX_CLAIMS_PER_SUBQ=5
# Max characters of each source kept in prompts (lower = fewer tokens used).
# CITEWISE_MAX_SOURCE_CHARS=600
# How many claims to fact-check in parallel (lower if your provider rate-limits).
# CITEWISE_FACTCHECK_WORKERS=2
# Minimum confidence (0-1) for a claim to count as verified.
# CITEWISE_ACCEPT_CONFIDENCE=0.6
# Retries on provider rate-limit (HTTP 429); honours the server's retry-after.
# CITEWISE_LLM_MAX_RETRIES=6
# Repetition penalty (0-2). Stops weak free models (e.g. llama-3.1-8b-instant)
# looping the same claim until the tool-call JSON breaks. 0 disables it.
# CITEWISE_FREQUENCY_PENALTY=0.6
