# Copy this file to `.env` and fill in your keys. NEVER commit the real .env.

# ============ LLM provider ============
# Choose ONE provider: groq | google | ollama | anthropic
CITEWISE_PROVIDER=groq

# --- Groq (free, fast — default). Free key: https://console.groq.com/keys ---
GROQ_API_KEY=your-groq-api-key-here
# CITEWISE_MODEL=llama-3.3-70b-versatile   # default for groq

# --- Google Gemini (free). Key: https://aistudio.google.com/app/apikey ---
# GOOGLE_API_KEY=your-google-api-key-here
# CITEWISE_MODEL=gemini-2.0-flash

# --- Anthropic Claude (needs credits). Key: https://console.anthropic.com ---
# ANTHROPIC_API_KEY=your-anthropic-api-key-here
# CITEWISE_MODEL=claude-opus-4-8

# --- Ollama (fully local; no key). Install https://ollama.com, `ollama pull llama3.1` ---
# Set CITEWISE_PROVIDER=ollama and CITEWISE_MODEL=llama3.1

# ============ Web search tool (Tavily) ============
# Free key: https://app.tavily.com
TAVILY_API_KEY=your-tavily-api-key-here

# ============ Observability (LangSmith) — optional ============
LANGSMITH_TRACING=false
LANGSMITH_API_KEY=your-langsmith-api-key-here
LANGSMITH_PROJECT=citewise

# ============ Behaviour ============
# Max times the Fact-Checker may loop back to the Researcher for more evidence.
MAX_RESEARCH_RETRIES=2
